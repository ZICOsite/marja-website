# PostgreSQL connection string
# For docker-compose: postgres://postgres:<POSTGRES_PASSWORD>@postgres:5432/marja-website
# For local dev:      postgres://postgres:<password>@127.0.0.1:5432/marja-website
DATABASE_URL=postgres://postgres:yourpassword@127.0.0.1:5432/marja-website

# Password for the PostgreSQL container (docker-compose only)
POSTGRES_PASSWORD=yourpassword
POSTGRES_USER=postgres

# Used to encrypt JWT tokens
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Used to configure CORS, format links and more. No trailing slash
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE

# Telegram bot notifications for form submissions
# Get bot token from @BotFather, chat_id from @userinfobot or channel/group id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# CRM integration (fill in when credentials are available)
CRM_API_URL=
CRM_API_KEY=
